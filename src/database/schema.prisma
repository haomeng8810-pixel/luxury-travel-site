// ============================================
// 枚举定义
// ============================================

enum InquiryStatus {
  NEW           // 新询盘
  CONTACTED     // 已联系
  IN_PROGRESS   // 跟进中
  QUOTED        // 已报价
  BOOKED        // 已预订
  CLOSED        // 已关闭
  LOST          // 流失
}

enum UserRole {
  CUSTOMER
  EXPERT
  ADMIN
}

enum ArticleType {
  STORY         // 品牌故事
  GUIDE         // 旅行指南
  FEATURE       // 专题
  NEWS          // 新闻
}

enum ChatRole {
  user
  assistant
}

enum ChatRole {
  user          // 用户消息
  assistant     // AI 回复
}

